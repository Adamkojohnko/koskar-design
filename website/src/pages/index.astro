---
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Koskar Design — AI Agent Skill</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:opsz,wght@9..40,400;9..40,500;9..40,600&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
  </head>
  <body>
    <main>
      <nav>
        <a href="https://github.com/Adamkojohnko/koskar-design" target="_blank" rel="noopener">GitHub</a>
      </nav>

      <section class="hero">
        <h1>Koskar Design</h1>
        <p class="tagline">Analyze any website, generate a DESIGN.md</p>

        <div class="install-block">
          <code id="install-command">npx skills add Adamkojohnko/koskar-design</code>
          <button id="copy-btn" aria-label="Copy to clipboard">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect>
              <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path>
            </svg>
          </button>
        </div>
        <p class="hint">Works with Claude Code, Codex, Cursor, OpenCode & more</p>
      </section>

      <section class="what">
        <h2>What it does</h2>
        <p>An AI agent skill that analyzes any website URL and produces a comprehensive DESIGN.md capturing its visual system — typography, colors, spacing, components, motion. Everything needed to recreate a similar style.</p>
      </section>

      <section class="how">
        <h2>How it works</h2>
        <div class="steps">
          <div class="step">
            <span class="step-num">01</span>
            <h3>Invoke</h3>
            <p>Run <code>koskar design [url]</code> or describe what you want</p>
          </div>
          <div class="step">
            <span class="step-num">02</span>
            <h3>Analyze</h3>
            <p>The agent visits the site, inspects CSS, identifies patterns</p>
          </div>
          <div class="step">
            <span class="step-num">03</span>
            <h3>Generate</h3>
            <p>Produces a DESIGN.md with implementation guidance</p>
          </div>
        </div>
      </section>

      <section class="started">
        <h2>Get started</h2>
        <ol>
          <li><code>npx skills add Adamkojohnko/koskar-design</code></li>
          <li>Ask your agent: <code>koskar design https://stripe.com</code></li>
          <li>Get your DESIGN.md</li>
        </ol>
      </section>

      <footer>
        <p>Coming soon — website & webapp for public access</p>
      </footer>
    </main>
  </body>
</html>

<style>
  :root {
    --bg: #0a0a0b;
    --text: #fafafa;
    --text-muted: #71717a;
    --accent: #fafafa;
    --accent-muted: #3f3f46;
    --code-bg: #18181b;
    --font-sans: 'DM Sans', system-ui, sans-serif;
    --font-mono: 'JetBrains Mono', monospace;
  }

  * {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
  }

  html {
    font-size: 16px;
    scroll-behavior: smooth;
  }

  body {
    font-family: var(--font-sans);
    background: var(--bg);
    color: var(--text);
    line-height: 1.6;
    min-height: 100vh;
    -webkit-font-smoothing: antialiased;
  }

  main {
    max-width: 640px;
    margin: 0 auto;
    padding: 3rem 1.5rem;
  }

  nav {
    display: flex;
    justify-content: flex-end;
    margin-bottom: 4rem;
  }

  nav a {
    color: var(--text-muted);
    text-decoration: none;
    font-size: 0.875rem;
    transition: color 0.2s ease;
  }

  nav a:hover {
    color: var(--text);
  }

  .hero {
    text-align: center;
    margin-bottom: 5rem;
  }

  .hero h1 {
    font-size: 2.5rem;
    font-weight: 600;
    letter-spacing: -0.03em;
    margin-bottom: 0.5rem;
    animation: fadeUp 0.6s ease both;
  }

  .tagline {
    color: var(--text-muted);
    font-size: 1.125rem;
    margin-bottom: 2.5rem;
    animation: fadeUp 0.6s ease 0.1s both;
  }

  .install-block {
    display: inline-flex;
    align-items: center;
    background: var(--code-bg);
    border: 1px solid var(--accent-muted);
    border-radius: 8px;
    padding: 0.75rem 1rem;
    gap: 0.75rem;
    animation: fadeUp 0.6s ease 0.2s both;
    transition: border-color 0.2s ease, box-shadow 0.3s ease;
  }

  .install-block:hover {
    border-color: var(--text-muted);
    box-shadow: 0 4px 24px rgba(0,0,0,0.4);
  }

  .install-block code {
    font-family: var(--font-mono);
    font-size: 0.9rem;
    color: var(--text);
  }

  .install-block button {
    background: none;
    border: none;
    color: var(--text-muted);
    cursor: pointer;
    padding: 0.25rem;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: color 0.2s ease, transform 0.2s ease;
    border-radius: 4px;
  }

  .install-block button:hover {
    color: var(--text);
    transform: scale(1.1);
  }

  .hint {
    font-size: 0.8rem;
    color: var(--text-muted);
    margin-top: 1rem;
    animation: fadeUp 0.6s ease 0.3s both;
  }

  section {
    margin-bottom: 4rem;
  }

  section h2 {
    font-size: 0.875rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--text-muted);
    margin-bottom: 1rem;
  }

  section p {
    color: var(--text);
    font-size: 1rem;
    line-height: 1.7;
  }

  .what p {
    max-width: 520px;
  }

  .steps {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  .step {
    padding: 1.25rem;
    background: linear-gradient(180deg, rgba(255,255,255,0.02) 0%, transparent 100%);
    border: 1px solid var(--accent-muted);
    border-radius: 8px;
  }

  .step-num {
    display: block;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--text-muted);
    margin-bottom: 0.75rem;
  }

  .step h3 {
    font-size: 1rem;
    font-weight: 500;
    margin-bottom: 0.5rem;
  }

  .step p {
    font-size: 0.875rem;
    color: var(--text-muted);
    line-height: 1.5;
  }

  .step code {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    background: var(--code-bg);
    padding: 0.125rem 0.375rem;
    border-radius: 3px;
  }

  .started ol {
    list-style: none;
    counter-reset: steps;
  }

  .started li {
    counter-increment: steps;
    display: flex;
    align-items: baseline;
    gap: 1rem;
    margin-bottom: 1rem;
    font-size: 0.95rem;
  }

  .started li::before {
    content: counter(steps);
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--text-muted);
    min-width: 1.5rem;
  }

  .started li code {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    background: var(--code-bg);
    padding: 0.25rem 0.5rem;
    border-radius: 4px;
    white-space: nowrap;
  }

  footer {
    text-align: center;
    padding-top: 2rem;
    border-top: 1px solid var(--accent-muted);
  }

  footer p {
    font-size: 0.875rem;
    color: var(--text-muted);
  }

  @keyframes fadeUp {
    from {
      opacity: 0;
      transform: translateY(12px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media (max-width: 600px) {
    main {
      padding: 2rem 1rem;
    }

    .hero h1 {
      font-size: 2rem;
    }

    .steps {
      grid-template-columns: 1fr;
    }

    .install-block {
      flex-direction: column;
      gap: 0.5rem;
    }

    .install-block code {
      font-size: 0.8rem;
    }
  }
</style>

<script>
  const copyBtn = document.getElementById('copy-btn');
  const command = document.getElementById('install-command');

  if (copyBtn && command) {
    copyBtn.addEventListener('click', async () => {
      await navigator.clipboard.writeText(command.textContent);
      copyBtn.innerHTML = '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"></polyline></svg>';
      setTimeout(() => {
        copyBtn.innerHTML = '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path></svg>';
      }, 2000);
    });
  }
</script>